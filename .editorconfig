# EditorConfig — ReadyRent.Gala / STANDARD.Rent
# https://editorconfig.org
#
# GAP-00 FIX (2026-03-31):
# Windows CRLF (\r\n) line endings were causing all grep/ripgrep forensic
# tools to return "No results found" even for features that clearly exist.
# This file enforces Unix LF (\n) across the entire project.
# Ref: AUDIT_BASELINE.md Section 12, GAP-00.

root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.py]
indent_size = 4
max_line_length = 120

[*.js]
indent_size = 2

[*.ts]
indent_size = 2

[*.tsx]
indent_size = 2

[*.json]
indent_size = 2

[*.yml]
indent_size = 2

[*.yaml]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
