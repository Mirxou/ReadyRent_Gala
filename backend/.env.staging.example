# Django Core Settings
DEBUG=True
SECRET_KEY=django-insecure-staging-key-change-in-provisioning
ALLOWED_HOSTS=staging-backend.readyrent.gala,localhost,127.0.0.1

# Database Configuration (Staging DB)
DB_NAME=readyrent_staging
DB_USER=readyrent_staging
DB_PASSWORD=staging_password_change_me
DB_HOST=localhost
DB_PORT=5432

# Redis Configuration
REDIS_URL=redis://localhost:6379/1
REDIS_HOST=localhost
REDIS_PORT=6379

# Celery Configuration
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Email Configuration (SMTP)
# Using Console Backend for Staging initially, or set real credentials
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=staging-email@readyrent.gala
EMAIL_HOST_PASSWORD=staging-app-password
DEFAULT_FROM_EMAIL=staging-noreply@readyrent.gala

# Security Settings (Staging)
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
CORS_ALLOWED_ORIGINS=https://staging.readyrent.gala,http://localhost:3000
CSRF_TRUSTED_ORIGINS=https://staging-backend.readyrent.gala

# File Storage (Staging S3 bucket)
USE_S3=True
AWS_ACCESS_KEY_ID=staging-aws-key
AWS_SECRET_ACCESS_KEY=staging-aws-secret
AWS_STORAGE_BUCKET_NAME=readyrent-staging
AWS_S3_REGION_NAME=us-east-1
AWS_S3_CUSTOM_DOMAIN=staging-cdn.readyrent.gala

# Image Optimization
IMAGE_OPTIMIZATION_ENABLED=True
IMAGE_QUALITY=80
CDN_DOMAIN=https://staging-cdn.readyrent.gala

# Google Maps API
GOOGLE_MAPS_API_KEY=your-staging-google-maps-key

# Sentry (Staging Project)
SENTRY_DSN=your-staging-sentry-dsn
SENTRY_ENVIRONMENT=staging
